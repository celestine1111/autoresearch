MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.seobetter.com
MAILGUN_REGION=us
EMAIL_TO=mindiamaiweb@gmail.com
EMAIL_FROM=SEOBetter Bot <bot@mg.seobetter.com>

OPENROUTER_API_KEY=sk-or-v1-...

# Hybrid model routing — cheap model for the 90% of runs that are
# search-and-reply, smart model for the 10% that are Loop 6 mentions
# (highest-leverage action: algo +75, 150× distribution multiplier)
MODEL=google/gemini-3.1-flash-lite-preview
MODEL_MENTIONS=google/gemini-3.1-pro-preview

# Browser fingerprint — MUST match the browser/OS where you extracted
# cookies, otherwise Twitter detects session-theft and invalidates the
# cookies in hours instead of the normal ~30 days.
#
# Defaults: Firefox + macOS UA + en-US + NY timezone (matches "extract
# cookies from Firefox on a Mac" flow). Override below if your cookie-
# source browser is different.
#
# How to get YOUR User-Agent: open the browser where you extract cookies,
# DevTools (F12) → Console → paste `navigator.userAgent` → copy the result
# into USER_AGENT below.
#
# BROWSER_TYPE valid values: firefox | chromium | webkit
# BROWSER_TYPE=firefox
# USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 14.15; rv:131.0) Gecko/20100101 Firefox/131.0
# LOCALE=en-GB
# TIMEZONE=Europe/London

# Optional residential proxy — RECOMMENDED for cookie longevity. The
# bot's IP must look like the IP that issued the cookie (same country at
# minimum). VPS data-center IPs replaying browser cookies are flagged as
# session theft within hours. ScrapeOps residential pool with a sticky
# session pinned to your country fixes this AND avoids x.com search
# suppression. Comment out to disable.
#
# ScrapeOps Residential Proxy (sticky session is REQUIRED for x.com —
# without `keep_session_id`, every request gets a fresh IP and Twitter
# challenges the session). Set `country` to match where you grab cookies
# from (e.g. uk if you browse from the UK, us if from the US):
# PROXY_URL=http://residential-proxy.scrapeops.io:8181
# PROXY_USER=scrapeops.country=uk.keep_session_id=seobetter1
# PROXY_PASS=YOUR_SCRAPEOPS_API_KEY
#
# IPRoyal / BrightData / Soax / Smartproxy:
# PROXY_URL=http://proxy.iproyal.com:12321
# PROXY_USER=your_username
# PROXY_PASS=your_password_country-uk
